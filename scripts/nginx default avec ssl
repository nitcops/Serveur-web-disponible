upstream mon_site_web {
    server 172.17.0.2; # Tes IPs Docker
    server 172.17.0.3;
}

server {
    listen 80;
    server_name _;
    return 301 https://$host$request_uri; # Redirection auto vers HTTPS
}

server {
    listen 443 ssl;
    server_name _;

    ssl_certificate /etc/ssl/certs/nginx-selfsigned.crt;
    ssl_certificate_key /etc/ssl/private/nginx-selfsigned.key;

    location / {
        proxy_pass http://mon_site_web;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    }
}
