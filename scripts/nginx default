### vim /etc/nginx/sites-available/default

upstream mon_site_web {
    # On définit les destinations (les IPs de tes conteneurs Docker)
    server 172.18.0.2; # Remplace par l'IP de web1
    server 172.18.0.3; # Remplace par l'IP de web2
}

server {
    listen 80;
    server_name localhost;

    location / {
        proxy_pass http://mon_site_web;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
    }
}
